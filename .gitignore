# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules

# next.js
/.next/
/out/

# production
/build

# firebase
firebase-debug.log
firebase-debug.*.log
.firebase/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (never commit secrets)
.env*
!.env.example

# service account key (local dev only — prefer FIREBASE_SERVICE_ACCOUNT_JSON in CI)
lib/firebase-private-key.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# os / editor (optional — remove if your team commits these)
.DS_Store
